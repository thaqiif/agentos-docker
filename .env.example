# Host directory to mount as the workspace inside the container.
# All your projects/code should live here.
WORKSPACE_DIR=/developer

# Run the container as your host user so files created under /workspaces are
# owned by you (not root) and are read/writable on both sides.
# Find your values by running `id` on the host: `id -u` and `id -g`.
PUID=1000
PGID=1000

# Extra Claude Code logins, each with its own isolated auth/config.
# Space-separated names -> claude-<name> wrappers, alongside the default `claude`.
# e.g. "a b c"  ->  claude-a, claude-b, claude-c
#      "work personal client1"  ->  claude-work, claude-personal, claude-client1
#
# Each profile also becomes a selectable harness in the AgentOS UI. Because that
# list is compiled into the app, apply changes with a rebuild:
#   docker compose up -d --build
# Removing a name does NOT delete its saved login: the config persists in the
# agent_os_claude_profiles volume, so adding the name back restores it.
CLAUDE_PROFILES=a b c

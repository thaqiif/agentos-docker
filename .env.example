# Host directory to mount as the workspace inside the container.
# All your projects/code should live here.
WORKSPACE_DIR=/developer

# Run the container as your host user so files created under /workspaces are
# owned by you (not root) and are read/writable on both sides.
# Find your values by running `id` on the host: `id -u` and `id -g`.
PUID=1000
PGID=1000

# Extra Claude Code logins, each with its own isolated auth/config.
# Space-separated names -> claude-<name> wrappers, alongside the default `claude`.
# e.g. "a b c"  ->  claude-a, claude-b, claude-c
#      "work personal client1"  ->  claude-work, claude-personal, claude-client1
#
# Each profile also becomes a selectable harness in the AgentOS UI. Because that
# list is compiled into the app, apply changes with a rebuild:
#   docker compose up -d --build
# Removing a name does NOT delete its saved login: the config persists in the
# agent_os_claude_profiles volume, so adding the name back restores it.
CLAUDE_PROFILES=a b c

# Terminal (xterm.js) font size in px — desktop and mobile (<768px) viewports.
# Baked into the client bundle, so changes need a rebuild:
#   docker compose up -d --build
# Upstream defaults are 14 / 11; these bump them up slightly.
TERMINAL_FONT_SIZE=16
TERMINAL_FONT_SIZE_MOBILE=13

# Which components to bake into the image. All default to true (installed);
# set any to false to skip it and shrink the image. Changes need a rebuild:
#   docker compose up -d --build
#
# AI coding agents — skip the CLIs you don't use. Note: turning off Claude Code
# disables the claude/claude-* harnesses, so leave it on unless you only use the
# others.
INSTALL_CLAUDE_CODE=true
INSTALL_CODEX=true
INSTALL_OPENCODE=true
INSTALL_COMMAND_CODE=true
INSTALL_ZERO=true
#
# Headless Chromium (+ system libs) so agents can render & screenshot the
# frontends they build. Adds a few hundred MB; set false if you don't need
# visual verification.
INSTALL_BROWSER=true
#
# Other optional components:
#   INSTALL_GH                  - GitHub CLI (gh) for PRs/issues/auth over HTTPS
#   INSTALL_JETBRAINS_MONO_FONT - self-hosted JetBrains Mono for terminal/code
#                                 blocks (off = system-monospace fallback)
#   INSTALL_AUTOPILOT           - autopilot-multi TDD slash commands & hooks
INSTALL_GH=true
INSTALL_JETBRAINS_MONO_FONT=true
INSTALL_AUTOPILOT=true
#
# Set to "true" to install Docker CLI inside the container and mount the host
# Docker socket. This lets agents run docker/build/push for their own testing.
# Requires a rebuild: docker compose up -d --build
ENABLE_DOCKER=true
